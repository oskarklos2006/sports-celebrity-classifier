   "source": [
    "import requests\n",
    "\n",
    "url = \"http://127.0.0.1:5000/predict\"\n",
    "\n",
    "image_path = \"test_images/Pogba_5.png\"\n",
    "\n",
    "with open(image_path, \"rb\") as f:\n",
    "    response = requests.post(\n",
    "        url,\n",
    "        files={\"image\": f}\n",
    "    )\n",
    "\n",
    "print(\"Status:\", response.status_code)\n",
    "print(\"Response:\", response.json())\n"
   ]
  }
 ],
